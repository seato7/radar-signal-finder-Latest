# MongoDB Connection
MONGO_URL=mongodb://mongo:27017
DB_NAME=opportunity_radar

# Frontend URL (for CORS)
FRONTEND_PUBLIC_URL=https://your-frontend-domain.com

# SEC Data Access
SEC_USER_AGENT=Opportunity Radar contact@your-domain.com
SEC_ACCEPT_LANGUAGE=en-US,en;q=0.9

# Data Sources (comma-separated URLs)
POLICY_FEEDS=https://www.sec.gov/news/pressreleases.rss,https://www.federalreserve.gov/feeds/press_all.xml
POLICY_KEYWORDS=regulation,policy,SEC,CFTC,Fed,treasury,banking

# ETF Data
ETF_FLOWS_CSV_URLS=
ETF_SECTOR_MAP_JSON=

# Price Data
PRICE_CSV_URLS=
CUSIP_MAP_CSV_URLS=

# OpenFIGI API (for symbol mapping)
OPENFIGI_API_KEY=

# Alert Configuration
ALERT_SCORE_THRESHOLD=2.0
HALF_LIFE_DAYS=30.0
TTL_DAYS=365

# ETL Configuration
ETL_TIMEOUT_SECONDS=15.0
ETL_RATE_LIMIT=5.0

# JWT Configuration
JWT_SECRET_KEY=YOUR_SECURE_RANDOM_SECRET_HERE
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Broker API Key Encryption (CRITICAL: Use separate key from JWT_SECRET_KEY)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BROKER_ENCRYPTION_KEY=YOUR_SEPARATE_BROKER_ENCRYPTION_KEY_HERE

# Stripe Payment Integration
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE
STRIPE_LITE_PRICE_ID=price_1SKByaRxVAVJnFJ4PcqG5uaX
STRIPE_STARTER_PRICE_ID=price_1SKBz4RxVAVJnFJ423DRGPZP
STRIPE_PRO_PRICE_ID=price_1SKBzORxVAVJnFJ4Pwee2TOR
STRIPE_PREMIUM_PRICE_ID=price_1SKBzsRxVAVJnFJ4OMUknOIZ

# Slack Notifications (optional)
SLACK_WEBHOOK=

# Email Service (optional - for alerts)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=YOUR_SENDGRID_API_KEY
EMAIL_FROM=alerts@your-domain.com
