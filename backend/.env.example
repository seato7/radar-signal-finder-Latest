MONGO_URL=mongodb://mongo:27017
DB_NAME=opportunity_radar

# Admin credentials (REQUIRED for admin user initialization)
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=your-secure-password-here

SLACK_WEBHOOK=
FRONTEND_PUBLIC_URL=http://localhost:5173

SEC_USER_AGENT=Opportunity Radar hello@example.com
SEC_ACCEPT_LANGUAGE=en-US,en;q=0.9

POLICY_FEEDS=
POLICY_KEYWORDS=regulation,policy,SEC,CFTC,Fed,treasury,banking

# ETF flows: comma-separated CSV URLs with columns [date,ticker,flow]
ETF_FLOWS_CSV_URLS=
# ETF to sector mapping: JSON object {"TICKER":"Sector Name"}
ETF_SECTOR_MAP_JSON={"SPY":"Broad Market","QQQ":"Technology","XLE":"Energy"}

PRICE_CSV_URLS=
CUSIP_MAP_CSV_URLS=

OPENFIGI_API_KEY=

ALERT_SCORE_THRESHOLD=2.0
HALF_LIFE_DAYS=30.0

JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Broker API Key Encryption (separate from JWT secret for security)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BROKER_ENCRYPTION_KEY=your-broker-encryption-key-change-in-production

# Supabase (for syncing data from Railway to Supabase)
SUPABASE_URL=https://detxhoqiarohjevedmxh.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ============================================================
# TWELVE DATA CONFIGURATION (Price Ingestion)
# ============================================================
# Get your API key from https://twelvedata.com/
TWELVEDATA_API_KEY=your-twelvedata-api-key

# Per-asset-class refresh intervals (in minutes)
# These match the Grow plan ($79/mo) rate limits
TD_REFRESH_CRYPTO_MINUTES=10
TD_REFRESH_FOREX_MINUTES=10
TD_REFRESH_STOCK_MINUTES=30
TD_REFRESH_COMMODITY_MINUTES=30

# Rate limiting (Grow plan: 55 credits/min)
TD_MAX_CREDITS_PER_MINUTE=55
TD_MAX_SYMBOLS_PER_BATCH=50

# ============================================================
# AI Features (set to 0 to disable AI summaries)
USE_AI_SUMMARIES=1
